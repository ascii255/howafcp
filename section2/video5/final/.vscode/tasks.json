{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-wasm-js-debug",
            "type": "shell",
            "command": "emcc",
            "args": [
                "pong.cpp",
                "--bind",
                "-g",
                "-sASSERTIONS",
                "-sSAFE_HEAP",
                "-o",
                "pong_wasm.js"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        },
        {
            "label": "touch-dwp-dummy",
            "type": "shell",
            "command": "touch",
            "args": [
                "pong_wasm.wasm.dwp"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        },
        {
            "label": "build-wasm-js-release",
            "type": "shell",
            "command": "emcc",
            "args": [
                "pong.cpp",
                "--bind",
                "-O3",
                "-o",
                "pong_wasm.js"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            },
            "dependsOn": [
                "touch-dwp-dummy"
            ]
        },
        {
            "label": "run-emrun-server",
            "type": "shell",
            "command": "emrun",
            "args": [
                "--no_browser",
                "--port",
                "8080",
                "${workspaceFolder}"
            ],
            "presentation": {
                "close": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "$^",
                        "file": 1,
                        "line": 1,
                        "column": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "^Now listening at (.+)$"
                }
            }
        },
        {
            "label": "build-and-serve-html-debug",
            "dependsOn": [
                "build-wasm-js-debug",
                "run-emrun-server"
            ],
            "dependsOrder": "sequence"
        },
        {
            "label": "build-and-serve-html-release",
            "dependsOn": [
                "build-wasm-js-release",
                "run-emrun-server"
            ],
            "dependsOrder": "sequence"
        },
        {
            "label": "kill-emrun-server",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "emrun",
                "||",
                "true"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        }
    ]
}