{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make debug js",
            "type": "shell",
            "command": "make debug js",
            "presentation": {
                "close": true
            }
        },
        {
            "label": "make debug serve",
            "type": "shell",
            "command": "make debug serve",
            "presentation": {
                "close": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "$^",
                        "file": 1,
                        "line": 1,
                        "column": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "^Now listening at (.+)$"
                }
            }
        },
        {
            "label": "make serve",
            "type": "shell",
            "command": "make serve",
            "presentation": {
                "close": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "$^",
                        "file": 1,
                        "line": 1,
                        "column": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "^Now listening at (.+)$"
                }
            }
        },
        {
            "label": "kill",
            "type": "shell",
            "command": "pkill -f emrun || true",
            "presentation": {
                "close": true
            }
        }
    ]
