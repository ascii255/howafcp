{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-wasm-cpp-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "hello_world.cpp",
                "-g",
                "-s", "PURE_WASI=1",
                "-o", "main.wasm",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build-wasm-node-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "hello_world.cpp",
                "-g",
                "-o", "main.js"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}