{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "JavaScript Debug",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/hello_world.js",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "preLaunchTask": "make debug js"
        },
        {
            "name": "HTML Debug",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080/hello_world.html",
            "runtimeExecutable": "/Applications/Chromium.app/Contents/MacOS/Chromium",
            "preLaunchTask": "make debug serve",
            "postDebugTask": "kill"
        },
        {
            "name": "HTML Release",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080/hello_world.html",
            "runtimeExecutable": "/Applications/Chromium.app/Contents/MacOS/Chromium",
            "preLaunchTask": "make serve",
            "postDebugTask": "kill"
        }
    ]
}