        {
            "label": "build-wasm-js-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "--bind",
                "pong.cpp",
                "-gseparate-dwarf=pong_wasm.wasm.dwp",
                "-o",
                "pong_wasm.js"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        },
        {
            "label": "touch-dwp-dummy",
            "type": "shell",
            "command": "touch",
            "args": [
                "pong_wasm.wasm.dwp"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        },
        {
            "label": "build-wasm-js-release",
            "type": "shell",
            "command": "em++",
            "args": [
                "--bind",
                "pong.cpp",
                "-O3",
                "-o",
                "pong_wasm.js"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            },
            "dependsOn": [
                "touch-dwp-dummy"
            ]
        },
        {
            "label": "run-emrun-server-debug",
            "type": "shell",
            "command": "emrun",
            "args": [
                "--no_browser",
                "--no_emrun_detect",
                "--port",
                "8080",
                "${workspaceFolder}"
            ],
            "presentation": {
                "close": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "$^",
                        "file": 1,
                        "line": 1,
                        "column": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "^Now listening at (.+)$"
                }
            },
            "dependsOn": [
                "build-wasm-js-debug"
            ]
        },
        {
            "label": "run-emrun-server-release",
            "type": "shell",
            "command": "emrun",
            "args": [
                "--no_browser",
                "--no_emrun_detect",
                "--port",
                "8080",
                "${workspaceFolder}"
            ],
            "presentation": {
                "close": true
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "$^",
                        "file": 1,
                        "line": 1,
                        "column": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "^Now listening at (.+)$"
                }
            },
            "dependsOn": [
                "build-wasm-js-release"
            ]
        },
        {
            "label": "kill-emrun-server",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "emrun",
                "||",
                "true"
            ],
            "presentation": {
                "close": true,
                "reveal": "silent"
            }
        },
    ]
}