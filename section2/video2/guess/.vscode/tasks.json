{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-wasm-cpp-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "guessing.cpp",
                "-g",
                "-s",
                "PURE_WASI=1",
                "-o",
                "main.wasm",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build-wasm-node-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "guessing.cpp",
                "-g",
                "-o",
                "main.js"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build-wasm-html-debug",
            "type": "shell",
            "command": "em++",
            "args": [
                "guessing.cpp",
                "-g",
                "-o",
                "main.html",
                "--emrun"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "start-emrun-server",
            "type": "shell",
            "command": "emrun",
            "args": [
                "--no_browser",
                "--port",
                "8080",
                "${workspaceFolder}"
            ],
            "isBackground": true,
            "dependsOn": [
                "build-wasm-html-debug"
            ]
        }
    ]
}